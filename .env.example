# ============================================================
# Trading Bot — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# LLM APIs
ANTHROPIC_API_KEY=sk-ant-...

# Data sources (optional — bot degrades gracefully without these)
# NewsAPI — free tier at https://newsapi.org (1000 req/day)
NEWS_API_KEY=

# Financial Modeling Prep — free tier at https://financialmodelingprep.com (250 req/day)
FMP_API_KEY=

# Broker — Demo / Practice account only
T212_API_KEY=
T212_API_SECRET=

# Budget & trading
BUDGET_PER_RUN_EUR=1000.0
MAX_PICKS_PER_RUN=5
MAX_DEMO_PORTFOLIO_INVESTED_EUR=46000.0

# Insider pipeline
INSIDER_LOOKBACK_DAYS=5
INSIDER_TOP_N=25
MIN_INSIDER_TICKERS=10
RESEARCH_TOP_N=15

# Capitol Trades (politician buy disclosures)
CAPITOL_TRADES_ENABLED=true
CAPITOL_TRADES_LOOKBACK_DAYS=3
CAPITOL_TRADES_TOP_N=10
CAPITOL_TRADES_RESERVED_SLOTS=3
CAPITOL_TRADES_MAX_MARKET_CAP=50000000000

# Stock variety — tickers bought are blacklisted for this many days
RECENTLY_TRADED_DAYS=3

# Orchestration
ORCHESTRATOR_TIMEZONE=Europe/Berlin
SCHEDULER_TRADE_DAYS=tue,fri
SCHEDULER_EXECUTE_TIME=17:10
SCHEDULER_EOD_TIME=17:35
SCHEDULER_SNAPSHOT_TIMES=10:00,15:30

# Telegram (optional)
TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Model overrides (defaults are fine, only change if needed)
# CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
# CLAUDE_SONNET_MODEL=claude-sonnet-4-6
# CLAUDE_OPUS_MODEL=claude-opus-4-6
# MAX_TOOL_ROUNDS=10
# PIPELINE_TIMEOUT_SECONDS=900
